{
  "manifest_version": 3,
  "name": "VK Multi Audio Upload",
  "version": "2.1",
  "description": "Мультизагрузка музыки во ВКонтакте + авто-плейлист + поиск дубликатов + скачивание плейлистов",
  "permissions": ["downloads"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://vk.com/*"],
      "js": ["injector_early.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://vk.com/*"],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": ["https://vk.com/*"]
    }
  ]
}
